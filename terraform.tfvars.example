# Copy to terraform.tfvars and edit for your local setup.
#
# `states` controls which YAML fragments under ./states/ are loaded and
# merged by the imported ../platformer/config module. Fragments are merged
# in left-to-right order; overlapping keys are resolved by last-wins.

states = [
  "core",
  # "fineweb-edu",   # enables the ingest container (streams fineweb-edu at 5 fragments/sec, capped at 1000 fragments)
  # "chat-http",     # HTTP chat endpoint (requires an http chat module - not yet scaffolded)
]
# The CLI chat tool (chat.py at repo root) needs no state fragment;
# run it after `terraform apply` with `python3 chat.py`.
